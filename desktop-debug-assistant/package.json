{
  "name": "leduo-debug-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win dir",
    "dist:portable": "npm run build && electron-builder --win portable"
  },
  "build": {
    "appId": "local.leduo.debug-assistant",
    "productName": "LeduO Debug Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "dir"
      ]
    },
    "portable": {
      "artifactName": "LeduO-Debug-Assistant.exe"
    }
  },
  "dependencies": {
    "aedes": "^1.0.2",
    "mqtt": "^5.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  }
}
